{
  "name": "luckin-na-qa-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.prep.json",
    "prep:collect": "tsx --env-file-if-exists=.env prep/collect.ts",
    "prep:validate": "tsx prep/validate.ts",
    "prep:export": "python3 prep/export_xlsx.py && python3 prep/export_docx.py",
    "prep:build": "npm run prep:collect && npm run prep:validate && npm run prep:export"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.6",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-to-print": "^3.0.5",
    "recharts": "^3.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
