# =============================================================================
# PREP-ONLY environment (used locally during the ONE-TIME data prep, never on Vercel).
# The deployed app (static /data read + on-demand Excel export) needs ZERO env vars.
# Copy to .env and fill in. Real .env and the business lists are gitignored.
# =============================================================================

# Socrata App Token — OPTIONAL. Not required for a one-time bulk pull (anonymous
# Socrata allows ~1,000 req/hr). Set it only to raise the throttle ceiling.
# Applies to NYC (data.cityofnewyork.us), CDC (data.cdc.gov), Cambridge.
SOCRATA_APP_TOKEN=

# Descriptive User-Agent for polite collection. REQUIRED for USDA/FSIS (its CDN
# returns 403 to headerless/bot requests). Identify the team + a contact.
FSIS_USER_AGENT=LuckinNA-QA-FoodSafety-Monitor/1.0 (contact: qa@example.com)
HTTP_USER_AGENT=LuckinNA-QA-FoodSafety-Monitor/1.0 (contact: qa@example.com)

# Business-sensitive inputs (gitignored). Paths to local JSON files.
STORE_LIST_PATH=./config/store_list.json
SUPPLIERS_PATH=./config/suppliers.json

# Where the prep pipeline writes versioned JSON that the app reads at build time.
PREP_OUTPUT_DIR=./data/v2

# ── Key-gated collectors (BUILT — add a key + re-run `npm run prep:collect` to activate) ──
# Each is free-tier. With no key a collector stays dormant: 0 rows + a truthful `manual`
# provenance stub on /sources (never fabricates). See docs/API_KEYS.md to register each.
FDA_OII_USER=          # FDA OII Import Refusals — Authorization-User header (Module 2)
FDA_OII_KEY=           # FDA OII Import Refusals — Authorization-Key header
LEGISCAN_KEY=          # LegiScan state bills, 30k queries/mo free (Module 3)
NY_SENATE_KEY=         # NY Senate OpenLegislation (Module 3)
OPENSTATES_KEY=        # OpenStates multi-state bills, ~500 req/day free (Module 3)
